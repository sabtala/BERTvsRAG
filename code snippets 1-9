Cell 2 — Load Dataset
# Load SQuAD — each example has a context, question, and answer span
dataset = load_dataset("squad")

# Fixed seed ensures same examples are selected every run
train_dataset = dataset["train"].shuffle(seed=42).select(range(20000))
val_dataset   = dataset["validation"].shuffle(seed=42).select(range(2000))

print("Train size:", len(train_dataset))
